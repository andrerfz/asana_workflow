# Asana Personal Access Token
# Get yours at: https://app.asana.com/0/my-apps → Create new token
ASANA_PAT=your_token_here

# Project & Section GIDs (pre-configured for your project)
ASANA_PROJECT_GID=your_project_gid_here
ASANA_SECTION_GID=your_section_gid_here

# Custom field GID for Story Points (where scope score syncs)
ASANA_STORY_POINT_FIELD_GID=your_field_gid_here

# Claude AI Classification (Optional - enables AI-powered classification)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Model for AI classification (default: haiku for speed/cost, use sonnet for better accuracy)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Auto-refresh interval in minutes (default: 5)
POLL_INTERVAL_MINUTES=5

# Projects root directory (REQUIRED for AI Agent feature)
# Mount point for all your code repos — the agent creates worktrees here
PROJECTS_DIR=/Users/youruser/Projects

# Docker GID for socket access (macOS Docker Desktop: 0, Linux: run `stat -c '%g' /var/run/docker.sock`)
DOCKER_GID=0

# Claude Code CLI OAuth token for headless container auth (valid 1 year)
# Generate with: claude setup-token  (requires Claude Code installed + logged in on your Mac)
# Or run: make setup-agent
CLAUDE_CODE_OAUTH_TOKEN=
