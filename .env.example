# Asana Personal Access Token
# Get yours at: https://app.asana.com/0/my-apps → Create new token
ASANA_PAT=your_token_here

# Project & Section GIDs (pre-configured for your project)
ASANA_PROJECT_GID=1120029023219792
ASANA_SECTION_GID=1204812858137872

# Custom field GID for Story Points (where scope score syncs)
ASANA_STORY_POINT_FIELD_GID=1204816034572110

# Claude AI Classification (Optional - enables AI-powered classification)
# Get yours at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_key_here

# Model for AI classification (default: haiku for speed/cost, use sonnet for better accuracy)
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Auto-refresh interval in minutes (default: 5)
POLL_INTERVAL_MINUTES=5
